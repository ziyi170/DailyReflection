<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>

    <!-- ✅ Live Activity 支持（必须在主 App target 里） -->
    <key>NSSupportsLiveActivities</key>
    <true/>
    <key>NSSupportsLiveActivitiesFrequentUpdates</key>
    <true/>

    <!-- Deep Link URL Scheme -->
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>dailyreflection</string>
            </array>
            <key>CFBundleURLName</key>
            <string>com.ziyi.DailyReflection</string>
        </dict>
    </array>

    <!-- 权限说明 -->
    <key>NSUserNotificationsUsageDescription</key>
    <string>需要发送通知提醒任务和倒计时</string>

    <key>NSCalendarsUsageDescription</key>
    <string>需要访问日历以同步任务事件</string>

    <key>NSCameraUsageDescription</key>
    <string>需要摄像头识别食物热量</string>

    <key>NSPhotoLibraryUsageDescription</key>
    <string>需要访问相册选择食物图片</string>

    <!-- 后台模式（白噪音需要） -->
    <key>UIBackgroundModes</key>
    <array>
        <string>audio</string>
    </array>

    <!-- 场景配置 -->
    <key>UIApplicationSceneManifest</key>
    <dict>
        <key>UIApplicationSupportsMultipleScenes</key>
        <false/>
    </dict>

    <!-- 启动屏 -->
    <key>UILaunchScreen</key>
    <dict/>

</dict>
</plist>